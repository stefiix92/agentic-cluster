# Public Kubernetes API: allow only your IP
kubernetes_api_allowed_cidrs = ["1.2.3.4/32"]

# Argo CD → Keycloak OIDC (HTTP dev ALB: two hostnames from `kubectl get ingress -A`)
argocd_public_url                    = "http://xxx"
argocd_oidc_issuer                   = "http://xxx/realms/agentic-cluster"
argocd_oidc_client_id                = "argocd"
argocd_oidc_client_secret            = "xxx"
argocd_oidc_tls_insecure_skip_verify = true